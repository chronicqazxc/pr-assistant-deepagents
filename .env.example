# =============================================================================
# PR Assistant Configuration
# =============================================================================
# This file contains the user-facing settings. Internal defaults are in agent_config.py
#
# For internal tuning (temperature, max_tokens, context_length, etc.), see:
#   src/pr_assistant/agents/agent_config.py
# =============================================================================

# LLM Provider (ollama, lm_studio, anthropic, gemini)
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# LM Studio (local)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=your-model-name

# Anthropic (remote)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini (remote)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# GitHub Integration
GH_TOKEN=ghp_your_personal_access_token_here
GITHUB_BASE_URL=https://api.github.com